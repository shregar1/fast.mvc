# MANIFEST.in - Specifies files to include in FastMVC source distribution

# Include essential files
include README.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
include requirements.txt
include uv.lock
include pytest.ini
include alembic.ini
include .coveragerc

# Include Docker files
include Dockerfile
include docker-compose.yml

# Include all JSON configuration files (application package lives under src/)
recursive-include src/config *.json

# Include migration files (if present at repo root)
recursive-include migrations *.py *.mako
include migrations/versions/.gitkeep

# Include all README files in subdirectories under src/
recursive-include src/abstractions *.md *.py
recursive-include src/constants *.md *.py
recursive-include src/controllers *.md *.py
recursive-include src/dependencies *.md *.py
recursive-include src/dtos *.md *.py
recursive-include src/fast_cli *.md *.py
recursive-include src/middlewares *.md *.py
recursive-include src/repositories *.md *.py
recursive-include src/services *.md *.py
recursive-include src/tests *.md *.py
recursive-include src/utilities *.md *.py

# Include type hints
global-include py.typed

# Exclude compiled and cache files
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
global-exclude *.egg-info
global-exclude .git
global-exclude .gitignore

# Exclude test artifacts
prune htmlcov
prune .pytest_cache
prune .coverage
prune .mypy_cache
prune .ruff_cache
prune build
prune dist
prune *.egg-info

# Exclude IDE files
prune .idea
prune .vscode
